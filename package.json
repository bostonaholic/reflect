{
  "name": "reflect",
  "description": "An AI tool to generate your brag document",
  "type": "module",
  "engines": {
    "node": ">=22.15.1",
    "npm": ">=10.9.0"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.8",
    "fast-check": "4.7.0",
    "husky": "9.1.7",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.2",
    "@dotenvx/dotenvx": "^2.0.0",
    "@octokit/graphql": "9.0.3",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "openai": "6.45.0",
    "ora": "9.3.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "typecheck": "tsc --noEmit",
    "console": "tsx bin/console.ts",
    "prepare": "husky"
  }
}
